{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["NODE_ENV"],
      "outputs": ["dist/**"],
      "cache": true
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "cache": true
    },
    "lint": {
      "dependsOn": [],
      "cache": true,
      "inputs": [
        "$TURBO_DEFAULT$",
        "eslint.config.*",
        "**/*.{js,jsx,ts,tsx}",
        "packages/eslint-config/**"
      ]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": [],
      "cache": true
    },
    "dev": {
      "persistent": true,
      "cache": false
    }
  },
  "globalDependencies": [
    "tsconfig.json",
    "package.json",
    "turbo.json",
    ".prettierrc",
    ".prettierignore",
    "packages/eslint-config/**",
    "packages/typescript-config/**"
  ]
}
