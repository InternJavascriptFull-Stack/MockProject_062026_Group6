# ── Database ─────────────────────────────────────────────────────────────────
# SQL Server SA password (used by docker-compose)
MSSQL_SA_PASSWORD=YourStrongPassword123!

# Prisma connection string — password MUST match MSSQL_SA_PASSWORD
DATABASE_URL="sqlserver://localhost:1433;database=nursing_home_db;user=sa;password=YourStrongPassword123!;encrypt=true;trustServerCertificate=true;"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Access token secret  (min 32 random chars)
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars

# Access token TTL (ms-compatible string: 15m, 1h, etc.)
JWT_ACCESS_EXPIRES_IN=15m

# Refresh token secret (different from access secret)
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars

# Refresh token TTL
JWT_REFRESH_EXPIRES_IN=7d

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3000

# ── eSMS Vietnam (https://esms.vn) ───────────────────────────────────────────
# Lấy ApiKey và SecretKey từ dashboard: https://esms.vn/Dashboard
ESMS_API_KEY=your_esms_api_key
ESMS_SECRET_KEY=your_esms_secret_key
# Brandname đã đăng ký (để trống nếu chưa có, sẽ dùng SmsType 4)
ESMS_BRAND_NAME=
