{
    "extends": "../typescript-config/base.json",
    "compilerOptions": {
        "rootDir": "./src",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "declaration": true,
        "declarationMap": false,
        "noEmit": false,
        "types": ["node"],
        "outDir": "./dist"
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
