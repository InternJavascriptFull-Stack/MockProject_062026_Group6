  isDeleted                                              Boolean                    @default(false, map: "DF__users__is_delete__5535A963") @map("is_deleted")
  deletedAt                                              DateTime?                  @map("deleted_at") @db.DateTimeOffset
  createdAt                                              DateTime                   @default(dbgenerated("sysdatetimeoffset()"), map: "DF__users__created_a__5629CD9C") @map("created_at") @db.DateTimeOffset
  updatedAt                                              DateTime                   @default(dbgenerated("sysdatetimeoffset()"), map: "DF__users__updated_a__571DF1D5") @updatedAt @map("updated_at") @db.DateTimeOffset
